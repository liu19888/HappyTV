    92|
    93|const CollapsibleTab = ({
    94|  title,
    95|  icon,
    96|  isExpanded,
    97|  onToggle,
    98|  children,
    99|}: CollapsibleTabProps) => {
   100|  return (
   101|    <div className='rounded-xl shadow-sm mb-4 overflow-hidden bg-white/80 backdrop-blur-md dark:bg-gray-800/50 dark:ring-1 dark:ring-gray-700'>
   102|      <button
   103|        onClick={onToggle}
   104|        className='w-full px-6 py-4 flex items-center justify-between bg-gray-50/70 dark:bg-gray-800/60 hover:bg-gray-100/80 dark:hover:bg-gray-700/60 transition-colors'
   105|      >
   106|        <div className='flex items-center gap-3'>
   107|          {icon}
   108|          <h3 className='text-lg font-medium text-gray-900 dark:text-gray-100'>
   109|            {title}
   110|          </h3>
   111|        </div>
   112|        <div className='text-gray-500 dark:text-gray-400'>
   113|          {isExpanded ? <ChevronUp size={20} /> : <ChevronDown size={20} />}
   114|        </div>
   115|      </button>
   116|
   117|      {isExpanded && <div className='px-6 py-4'>{children}</div>}
   118|    </div>
   119|  );
   120|};
